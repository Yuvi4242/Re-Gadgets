# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/re-gadgets
MONGO_POOL_SIZE=10

# JWT (access + refresh) — generate long random secrets
ACCESS_TOKEN_SECRET=change_me_access_secret_min_32_chars
REFRESH_TOKEN_SECRET=change_me_refresh_secret_min_32_chars
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Frontend origin (CORS + password-reset links)
CLIENT_URL=http://localhost:5173

# Gmail SMTP (Nodemailer) — use an App Password, not your login password
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# Cloudinary (Multer uploads: ID proofs, verification docs, avatars)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google OAuth (Sign in with Google)
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Google Generative AI (Gemini chat assistant) — optional; mock fallback if missing
GEMINI_API_KEY=your_gemini_api_key
